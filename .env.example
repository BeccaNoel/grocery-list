SKYLIGHT_BACKEND=mcp
SKYLIGHT_EMAIL=your_email@example.com
SKYLIGHT_PASSWORD=your_password
# Use the Skylight household/frame ID from a real /api/frames/{id}/... request, not a display name.
SKYLIGHT_FRAME_ID=your_frame_id

# Optional for SKYLIGHT_BACKEND=api.
SKYLIGHT_LIST_ID=your_grocery_list_id

# Optional for SKYLIGHT_BACKEND=mcp when you want a named list instead of the default grocery list.
# SKYLIGHT_LIST_NAME=Grocery List

# Optional for SKYLIGHT_BACKEND=mcp token-based auth.
# SKYLIGHT_TOKEN=your_token_here
# SKYLIGHT_AUTH_TYPE=bearer
# SKYLIGHT_TIMEZONE=America/New_York

# When vendor/skylight-mcp/dist/index.js exists, the app prefers that local source build.
# Otherwise it falls back to the published package: npx -y @eaglebyte/skylight-mcp
# SKYLIGHT_MCP_COMMAND=npx
# SKYLIGHT_MCP_ARGS=-y @eaglebyte/skylight-mcp
# SKYLIGHT_MCP_TIMEOUT_SECONDS=20

# To rebuild the local source checkout:
#   cd vendor/skylight-mcp && npm install && npm run build

# Use either a numeric webcam index like 0 or an RTSP URL.
CAMERA_INDEX=rtsp://user:pass@camera-ip:554/Preview_01_sub

DOOR_OPEN_DETECTION_ENABLED=true
DOOR_OPEN_SAMPLE_FPS=5
DOOR_OPEN_MOTION_RATIO_THRESHOLD=0.08
DOOR_OPEN_INTENSITY_THRESHOLD=25
DOOR_OPEN_SETTLE_SECONDS=1.25
DOOR_OPEN_COOLDOWN_SECONDS=20
DOOR_OPEN_MIN_MOTION_SECONDS=0.35

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava

SCAN_INTERVAL_HOURS=4
POINTING_HOLD_SECONDS=2
FLAG_THRESHOLD=2
UNKNOWN_ITEM_THRESHOLD=3
CAMERA_RETRY_ATTEMPTS=3
CAMERA_RETRY_DELAY_SECONDS=5
OLLAMA_TIMEOUT_SECONDS=30
SKYLIGHT_TIMEOUT_SECONDS=10

ADMIN_UI_REFRESH_SECONDS=5
ADMIN_UI_HOST=127.0.0.1
ADMIN_UI_PORT=8765

LOG_RETENTION_DAYS=7
LOG_FILE_MAX_BYTES=5242880
LOG_BACKUP_COUNT=10

# Optional override for the default staples list.
# STAPLES=milk,eggs,bread